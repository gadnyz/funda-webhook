PORT=3000
HOST=0.0.0.0
APP_ENV=development
APP_TIME_ZONE=Africa/Cairo

# Token libre choisi par toi, puis copie dans Meta > Webhooks > Verify token.
WHATSAPP_VERIFY_TOKEN=la-nouvelle-facon-d-apprendre

# Informations fournies par Meta WhatsApp Business / Cloud API.
WHATSAPP_ACCESS_TOKEN=remplacer_par_ton_access_token
WHATSAPP_PHONE_NUMBER_ID=remplacer_par_ton_phone_number_id
WHATSAPP_APP_SECRET=remplacer_par_ton_app_secret
WHATSAPP_API_VERSION=v25.0

# Optionnel: IDs Meta utilises par la console /admin de tests avant publication.
META_GRAPH_API_VERSION=v25.0
META_APP_ID=
META_BUSINESS_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_TEST_RECIPIENT_WA_ID=
FACEBOOK_TEST_USER_ACCESS_TOKEN=

# En development, si le token ou le phone number manquent, le bot tourne en dry-run.
WHATSAPP_DRY_RUN=false

DATABASE_PATH=./data/funda.sqlite
BACKUP_DIR=./data/backups
PUBLIC_BASE_URL=https://example.com
# Choisis une vraie valeur. Les valeurs commencant par change-me ou remplacer_par_ sont ignorees.
ADMIN_TOKEN=funda-admin-local-token-a-remplacer
ADMIN_PUBLIC=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120

# Optionnel: image publique envoyee dans le message d'accueil.
# FUNDA_IOT_IMAGE_URL=
